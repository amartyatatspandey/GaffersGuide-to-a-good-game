# Copy to .env.runpod (do not commit) and: set -a; source .env.runpod; set +a
# RunPod network volume → S3 API (from RunPod dashboard for your volume).

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional overrides (defaults match your EU-RO-1 volume).
RUNPOD_S3_BUCKET=6x4jz4yym1
RUNPOD_S3_ENDPOINT=https://s3api-eu-ro-1.runpod.io

# Object key prefix inside the bucket (folder name on the volume mount).
RUNPOD_S3_PREFIX=gaffers-experiment-repo

# Sync: omit local benchmark/job output to save space (optional).
# EXCLUDE_LOCAL_OUTPUT=1

# Dry run: no uploads, list actions only.
# DRY_RUN=1

# Mirror: delete remote keys not present locally (optional, risky).
# RUNPOD_S3_SYNC_DELETE=1

# Gaffer's Guide – environment template
# Copy to .env and set values. Never commit .env.

# SoccerNet data download (NDA password from soccer-net.org)
SOCCERNET_PASSWORD=

# Optional: API keys (use for production; leave empty for local dev)
# Google Gemini (preferred for coaching text in backend/main.py and run_e2e.py)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# SKILLCORNER_API_KEY=
# GCP_PROJECT_ID=

# AI Coaching API (OpenAI-compatible; used if GEMINI_API_KEY is unset)
# LLM_API_KEY=
# Optional overrides:
# LLM_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=   # e.g. Azure or proxy; omit for api.openai.com

# Copy to `.env` in repo root or `backend/.env` (see main.py load_dotenv).

# YOLO / ByteTrack weights for local CV (default: backend/models/pretrained/best.pt).
# Use an absolute path if weights live elsewhere or the job runs in Docker with a different filesystem.
# TRACKING_MODEL_PATH=/absolute/path/to/best.pt

# Local LLM (Ollama). Backend calls this from Python — not the browser.
# Same variables are used for job-time CV pipeline LLM (llm_engine=local), coach refresh, and /api/v1/chat.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
# OLLAMA_TIMEOUT_SECONDS=120
# Auto-start `ollama serve` when the CLI is on PATH but the daemon is down.
# Default: ON when unset and not on Cloud Run. Set OLLAMA_AUTO_START=0 to disable.
# On Cloud Run (K_SERVICE), default is OFF unless OLLAMA_AUTO_START_IN_CLOUD=1.
# OLLAMA_AUTO_START=0
# OLLAMA_AUTO_START_IN_CLOUD=1
# Start Ollama with uvicorn and stop it when the API exits (only the child this app spawned).
# Also enabled when GAFFERS_DEFAULT_LLM_ENGINE=local. Same Cloud Run guard as above.
# OLLAMA_MANAGED_LIFECYCLE=1
# After daemon is up, run `ollama pull $OLLAMA_MODEL` once (slow; optional).
# OLLAMA_PULL_ON_START=1
# Default LLM for jobs/UI when not specified (backend uses "local" to start Ollama with the app).
# GAFFERS_DEFAULT_LLM_ENGINE=local

# If FastAPI runs in Docker and Ollama on the host:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Cloud LLM (optional; used when llm_engine=cloud)
# GEMINI_API_KEY=
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

# Homography (TacticalRadar): per-upload file backend/output/{video_stem}_homographies.json
# (same stem as the uploaded .mp4, usually the job id). Auto-created during CV if
# backend/references/sn-calibration/resources/ exists and this variable is UNSET.
# Setup: clone https://github.com/SoccerNet/sn-calibration under backend/references/sn-calibration
# and populate resources/ per upstream README. Verify: python scripts/verify_sn_calibration.py
# Manual generate (from backend/): python scripts/run_calibrator_on_video.py --video data/uploads/<id>.mp4
# Override only when pointing at an existing JSON (disables per-stem auto-calibration):
# GAFFERS_HOMOGRAPHY_JSON=/absolute/path/to/custom_homographies.json

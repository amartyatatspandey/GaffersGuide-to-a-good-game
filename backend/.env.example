# Copy to `.env` in repo root or `backend/.env` (see main.py load_dotenv).

# Local LLM (Ollama). Backend calls this from Python — not the browser.
# Same variables are used for job-time CV pipeline LLM (llm_engine=local), coach refresh, and /api/v1/chat.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
# OLLAMA_TIMEOUT_SECONDS=120

# If FastAPI runs in Docker and Ollama on the host:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Cloud LLM (optional; used when llm_engine=cloud)
# GEMINI_API_KEY=
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
